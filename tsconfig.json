{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    /* 
      AGREGADO: La propiedad "types" le dice a TypeScript qué definiciones de tipos globales debe cargar.
      - "vitest/globals": Permite que tu editor reconozca funciones como 'describe', 'test' o 'expect' sin que te marque errores de "no se encuentra el nombre".
      - "@testing-library/jest-dom": Le enseña al autocompletado del editor que los elementos HTML ahora tienen métodos como '.toBeVisible()' o '.toBeInTheDocument()'.
    */
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["next-env.d.ts",
   "**/*.ts",
    "**/*.tsx",
     ".next/types/**/*.ts"
    ,
    /*
      AGREGADO: Incluimos explícitamente el archivo de configuración inicial de Vitest.
      Esto garantiza que TypeScript procese las importaciones de extensiones que pusimos dentro de 'vitest.setup.ts'
      y las aplique a todo el proyecto de testing.
    */
    "vitest.setup.ts"
    ],
  "exclude": ["node_modules"]
}
